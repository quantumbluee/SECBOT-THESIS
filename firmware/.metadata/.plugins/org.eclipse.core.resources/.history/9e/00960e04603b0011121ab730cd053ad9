/**
  * @brief  The application entry point.
  * @retval int
  */
int main(void)
{

  /* USER CODE BEGIN 1 */

  /* USER CODE END 1 */

  /* MCU Configuration--------------------------------------------------------*/

  /* Reset of all peripherals, Initializes the Flash interface and the Systick. */
  HAL_Init();

  /* USER CODE BEGIN Init */

  /* USER CODE END Init */

  /* Configure the system clock */
  SystemClock_Config();

  /* Configure the peripherals common clocks */
  PeriphCommonClock_Config();

  /* USER CODE BEGIN SysInit */

  /* USER CODE END SysInit */

  /* Initialize all configured peripherals */
  MX_GPIO_Init();
  MX_ADC1_Init();
  MX_ADC2_Init();
  MX_ADC3_Init();
  MX_FMC_Init();
  MX_I2C1_Init();
  MX_I2C2_Init();
  MX_I2C3_Init();
  MX_QUADSPI_Init();
  MX_SAI2_Init();
  MX_SPI1_Init();
  MX_SPI2_Init();
  MX_TIM2_Init();
  MX_TIM3_Init();
  MX_TIM5_Init();
  MX_TIM9_Init();
  MX_TIM12_Init();
  MX_UART4_Init();
  MX_UART5_Init();
  MX_UART7_Init();
  MX_USART2_UART_Init();
  MX_USART6_UART_Init();
  MX_USB_HOST_Init();
  printf("ST, UART7 openmv bridge starting \r\n");

  /* USER CODE BEGIN 2 */
  //GPS Init
  //GPS_Init(&huart2);

  s_node_payload_t payload = {0};
  uint8_t hash[HASH_SHA256_SIZE];
  uint8_t frame_buf[1024];
  /* USER CODE END 2 */


  //I2C init
  printf("Scanning for I2C devices\r\n");
  for(uint8_t addr=1;addr < 127; addr++){
	  if(HAL_I2C_IsDeviceReady(&hi2c2, addr << 1, 1, 10) == HAL_OK) {
		  printf("Found devices at 0x%02X\r\n", addr);
	  }
  }
  printf("Scan done.\r\n");
  //IMU INIT
  if(IMU_Init(&hi2c2)!=0)
  {
	  printf("IMU init failed\r\n");
  }
  else{
	  printf("IMU Init okay\r\n");
  }

  printf("sizeof(payload) = %u\r\n", (unsigned)sizeof(payload));
  /* USER CODE BEGIN WHILE */
  while (1)
  {
      MX_USB_HOST_Process();

      imu_data_t imu = {0};
      int imu_rc = IMU_Read(&imu);

      if (imu_rc != 0){
    	  printf("IMU read error: %d\r\n", imu_rc);
    	  HAL_Delay(200);
    	  continue;
      }

      payload_fill_from_sensors(&payload, NULL, &imu);

      //HMAC
      if (HASH_HMAC_SHA256(HMAC_KEY, sizeof(HMAC_KEY)-1, (const uint8_t*)&payload, sizeof(payload), hash)!=0){
    	  printf("HMAC_SHA256 failed\r\n");
    	  HAL_Delay(500);
    	  continue;
      }

      int frame_len = frame_build(frame_buf,
                                  sizeof(frame_buf),
                                  (uint8_t*)&payload,
                                  sizeof(payload),
                                  hash);

      if (frame_len < 0) {
          printf("frame build error: %d\r\n", frame_len);
          HAL_Delay(500);
          continue;
      }

      HAL_UART_Transmit(&huart4, frame_buf, frame_len, HAL_MAX_DELAY);
      printf("Sent frame to Pi: len = %d |"
    		  "Ax=%.3f Ay=%.3f Az=%.3f |"
    		  "Gx=%.3f Gy=%.3f Gz=%.3f |"
    		  "T=%.2f C\r\n",
			  frame_len, imu.accel_x, imu.accel_y, imu.accel_z,
			  imu.gyro_x, imu.gyro_y, imu.gyro_z,
			  imu.temp_c);

      HAL_Delay(200);
  }
}
